# ============================================================
# TikTokSave Backend - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Server ───────────────────────────────────────────────────
PORT=3001

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Development:  http://localhost:5500,http://127.0.0.1:5500
# Production:   https://your-app.vercel.app
FRONTEND_URL=http://localhost:5500

# ── Rate Limiting ─────────────────────────────────────────────
# Max requests per windowMs (milliseconds)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=10

# ── ssstik.io API ─────────────────────────────────────────────
# No API key required — ssstik uses form-based POST
SSSTIK_API_URL=https://ssstik.io/abc

# ── tikwm.com API ─────────────────────────────────────────────
# Fallback API — free, no key needed
TIKWM_API_URL=https://www.tikwm.com/api/
